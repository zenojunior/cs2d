{
  "name": "cs2-demo-viewer-extension",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "description": "CS Demo Analyzer: open any Faceit CS2 match as a 2D replay in one click, parsed locally and 100% offline.",
  "scripts": {
    "postinstall": "wxt prepare",
    "predev": "node scripts/sync-zstd-wasm.mjs",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "prebuild": "node scripts/sync-zstd-wasm.mjs",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "type-check": "wxt prepare && vue-tsc --noEmit"
  },
  "dependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "@cs2/replay-core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.469.0",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/chrome": "^0.0.270",
    "@wxt-dev/module-vue": "^1.0.3",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.0",
    "wxt": "^0.20.6"
  }
}
